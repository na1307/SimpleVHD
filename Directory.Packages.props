<Project>
  <PropertyGroup>
    <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
  </PropertyGroup>
  <ItemGroup>
    <PackageVersion Include="JsonSchema.Net" Version="6.0.2" />
    <PackageVersion Include="System.Management" Version="8.0.0" />
    <PackageVersion Include="Bluehill.Features" Version="0.2.0" />
    <PackageVersion Include="Bluehill.Forms" Version="0.1.2" />
    <PackageVersion Include="Bluehill.Bcd" Version="1.0-alpha.1" />
    <PackageVersion Include="Microsoft.WindowsAppSDK" Version="1.5.240205001-preview1" />
    <PackageVersion Include="Microsoft.Windows.SDK.BuildTools" Version="10.0.22621.2428" />
    <PackageVersion Include="WinUIEx" Version="2.3.3" />
    <PackageVersion Include="Microsoft.NET.Test.Sdk" Version="17.9.0" />
    <PackageVersion Include="xunit" Version="2.6.6" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Bluehill.Features" />
  </ItemGroup>
  <ItemGroup Condition="'$(IsTestProject)' == 'true'">
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit" />
    <GlobalPackageReference Include="xunit.runner.visualstudio" Version="2.5.6" />
  </ItemGroup>
</Project>
